{
  "name": "mgo2-foxdie",
  "version": "1.0.0",
  "description": "MGO2 Network Tool - DNS Interception, HTTP Proxy, TCP Proxy with Dear ImGui",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start": "tsx src/main.ts",
    "dns": "tsx --env-file=.env src/dns-standalone.ts",
    "test": "tsx --test src/tcp-proxy.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "tsc --project tsconfig.ui.json",
    "build:ui": "esbuild src/ui/main.ts --bundle --format=esm --outfile=public/app.js --external:/jsimgui/mod.js --platform=browser",
    "dev:ui": "esbuild src/ui/main.ts --bundle --format=esm --outfile=public/app.js --external:/jsimgui/mod.js --platform=browser --watch"
  },
  "dependencies": {
    "dns-packet": "^5.6.1",
    "@mori2003/jsimgui": "^0.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0"
  }
}
